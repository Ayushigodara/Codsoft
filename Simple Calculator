#include <iostream>
using namespace std;

int main()
{
    int num1, num2;
    char ch;

    cout << "Enter first number: ";
    cin >> num1;

    cout << "Enter operator (+,-,*,/): ";
    cin >> ch;

    cout << "Enter second number: ";
    cin >> num2;

    if(ch == '+')
    {
        cout << "Result = " << num1 + num2;
    }
    else if(ch == '-')
    {
        cout << "Result = " << num1 - num2;
    }
    else if(ch == '*')
    {
        cout << "Result = " << num1 * num2;
    }
    else if(ch == '/')
    {
        if(num2 != 0)
        {
            cout << "Result = " << num1 / num2;
        }
        else
        {
            cout << "Division by zero is not possible";
        }
    }
    else
    {
        cout << "Invalid operator";
    }

    return 0;
}
